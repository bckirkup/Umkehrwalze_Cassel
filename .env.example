# Copy to .env in the project root and adjust paths.
# See src/revprint/config.py for full documentation of each variable.

# Required: root directory containing manuscript JPEG scans
RPK_INPUT_ROOT=inputs/text_dense_8

# Job and project tracking (SQLite databases)
RPK_JOB_STORE=data/jobs.sqlite
RPK_PROJECT_STORE=data/projects.sqlite

# Processing profile: quick, balanced, forensic, training
RPK_PROCESSING_PROFILE=balanced

# Optional: Google Cloud Translation API v2 key (for translation PDF)
# RPK_GOOGLE_TRANSLATE_API_KEY=

# Optional: Gemini vision translation
# RPK_GEMINI_API_KEY=
# RPK_GEMINI_ENABLED=false
# RPK_GEMINI_MODEL=gemini-2.5-flash

# Translation caching
# RPK_TRANSLATION_CACHE=true
# RPK_TRANSLATION_CACHE_PATH=data/translation_cache.json
# RPK_GEMINI_CACHE=true
# RPK_GEMINI_CACHE_PATH=data/gemini_cache.json

# Ghost suppression (proof pipeline)
# RPK_GHOST_SUPPRESSION=false
# RPK_GHOST_CONFIDENCE_MIN=0.18
# RPK_GHOST_PLAUSIBILITY_MIN=0.55

# Dewarp (proof pipeline)
# RPK_DEWARP=false

# Crease/shadow suppression
# RPK_CREASE_REFINE=true
# RPK_CREASE_DARKNESS_THRESHOLD=12.0

# Speckle removal
# RPK_SPECKLE_REFINE=true
# RPK_SPECKLE_MAX_COMPONENT_AREA=36

# Line artifact removal
# RPK_LINE_REFINE=true

# Edge reconstruction
# RPK_EDGE_RECONSTRUCT=false

# HTR sidecar ingestion
# RPK_HTR_ENABLED=true

# OCR settings
# RPK_OCR_TRANSLATION_CONFIDENCE_MIN=0.34
# RPK_OCR_RECONSTRUCT_HINT=true
